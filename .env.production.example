# ── COPY THIS FILE TO .env ON YOUR PRODUCTION SERVER ─────────────────────────
# Never commit this file with real values.

PORT=3002
NODE_ENV=production

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Generate your own: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=84af4fc6985287ee8414a7adf553b21ed9e7faeddef24f11a851445b56847595153e5353da86242af63c59d995072c50

# ── ADMIN ACCOUNT (only used on first startup to create the admin) ────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ── ADMIN RESET SECRET (used to verify identity on forgot-password) ───────────
# Set this to a secret phrase only you know. Required for admin password reset.
ADMIN_RESET_SECRET=CHANGE_THIS_TO_YOUR_SECRET_PHRASE

# ── RATE LIMITING (for 2000+ users) ───────────────────────────────────────────
# Global rate limit (requests per 15 minutes per IP)
RATE_LIMIT_MAX=1000

# Auth rate limit (login attempts per 15 minutes per IP)
AUTH_RATE_LIMIT=20

# Sensitive operations rate limit (per hour per IP)
SENSITIVE_OP_LIMIT=100

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Get this from your cloud provider (Railway, Supabase, Neon, Render, etc.)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.egomeijwlgeuocrkbfer.supabase.co:5432/postgres

# Database connection pool settings (critical for 2000+ users)
DB_POOL_MAX=20
DB_POOL_MIN=2

# ── REDIS (highly recommended for 2000+ users) ────────────────────────────────
# Improves performance through caching and reduces database load
# Get free tier from: Upstash, Redis Cloud, or run your own
# REDIS_URL=redis://default:password@your-redis-host:6379
# or for Redis Cloud: rediss://default:password@host:port

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your exact frontend domain — no trailing slash
CORS_ORIGIN=https://your-frontend-domain.com

# ── SMS NOTIFICATIONS ─────────────────────────────────────────────────────────
# Enable/disable SMS notifications
SMS_ENABLED=false

# SMS Provider: 'africastalking', 'twilio', 'http', or 'none'
SMS_PROVIDER=none

# Africa's Talking (for Ethiopia) - https://africastalking.com
# Sign up at https://africastalking.com and get your credentials
# AFRICASTALKING_USERNAME=your_username
# AFRICASTALKING_API_KEY=your_api_key_here
# AFRICASTALKING_SENDER_ID=WAZEMA

# Twilio (international) - https://twilio.com
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Generic HTTP Gateway (custom SMS provider)
# SMS_HTTP_GATEWAY_URL=https://your-sms-gateway.com/send
# SMS_HTTP_GATEWAY_KEY=your_api_key
# SMS_SENDER_ID=WAZEMA

# ── FINANCIAL SECURITY & COMPLIANCE (CRITICAL) ────────────────────────────────
# Data encryption for sensitive financial data (MANDATORY for production)
# Generate strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_ENCRYPTION_KEY=GENERATE_YOUR_OWN_64_CHAR_KEY_HERE

# Automated backups (CRITICAL - DO NOT DISABLE in production)
BACKUP_ENABLED=true
BACKUP_DIR=/var/backups/wazema
BACKUP_RETENTION_DAYS=90
BACKUP_SCHEDULE=daily

# Backup encryption (HIGHLY RECOMMENDED for financial data)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=GENERATE_YOUR_OWN_64_CHAR_BACKUP_KEY_HERE

# Data integrity checks (automated validation - recommended)
INTEGRITY_CHECKS_ENABLED=true

# Cloud backup to S3 (optional but recommended for disaster recovery)
# S3_BACKUP_BUCKET=wazema-production-backups
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_REGION=us-east-1
