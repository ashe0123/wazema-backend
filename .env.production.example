# ── COPY THIS FILE TO .env ON YOUR PRODUCTION SERVER ─────────────────────────
# Never commit this file with real values.

PORT=3002
NODE_ENV=production

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Generate your own: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=84af4fc6985287ee8414a7adf553b21ed9e7faeddef24f11a851445b56847595153e5353da86242af63c59d995072c50

# ── ADMIN ACCOUNT (only used on first startup to create the admin) ────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ── ADMIN RESET SECRET (used to verify identity on forgot-password) ───────────
# Set this to a secret phrase only you know. Required for admin password reset.
ADMIN_RESET_SECRET=CHANGE_THIS_TO_YOUR_SECRET_PHRASE

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Get this from your cloud provider (Railway, Supabase, Neon, Render, etc.)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.egomeijwlgeuocrkbfer.supabase.co:5432/postgres

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your exact frontend domain — no trailing slash
CORS_ORIGIN=https://your-frontend-domain.com
