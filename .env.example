# ── ADMIN ACCOUNT (only used on first startup to seed the admin) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend domain in production, or leave empty to allow all origins
# CORS_ORIGIN=https://your-domain.com

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Priority: PostgreSQL > Turso > Local SQLite
#
# Option 1: PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@host:5432/wazema_db

# Option 2: Turso cloud SQLite
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_token_here

# Option 3: Local SQLite (development only — no env vars needed, auto fallback)
