# ── ADMIN ACCOUNT (only used on first startup to seed the admin) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ── RATE LIMITING (adjust for your scale) ────────────────────────────────────
# Global rate limit (requests per 15 minutes per IP)
RATE_LIMIT_MAX=1000

# Auth rate limit (login attempts per 15 minutes per IP)
AUTH_RATE_LIMIT=20

# Sensitive operations rate limit (per hour per IP)
SENSITIVE_OP_LIMIT=100

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend domain in production, or leave empty to allow all origins
# CORS_ORIGIN=https://your-domain.com

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Priority: PostgreSQL > Turso > Local SQLite
#
# Option 1: PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@host:5432/wazema_db

# Database connection pool settings (for 2000+ users)
DB_POOL_MAX=20
DB_POOL_MIN=2

# Option 2: Turso cloud SQLite
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_token_here

# Option 3: Local SQLite (development only — no env vars needed, auto fallback)

# ── REDIS (optional, for caching and performance) ────────────────────────────
# Recommended for production with 2000+ users
# Redis URL format: redis://username:password@host:port
# REDIS_URL=redis://localhost:6379
# or for Redis Cloud: rediss://default:password@host:port

# ── FINANCIAL SECURITY & COMPLIANCE ───────────────────────────────────────────
# Data encryption (HIGHLY RECOMMENDED for financial systems)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DATA_ENCRYPTION_KEY=your_64_character_encryption_key_here

# Automated backups (CRITICAL for financial data protection)
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=90
BACKUP_SCHEDULE=daily

# Backup encryption (recommended for sensitive financial data)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BACKUP_ENCRYPTION_KEY=your_64_character_backup_encryption_key_here

# Data integrity checks (automated validation)
INTEGRITY_CHECKS_ENABLED=true

# Optional: Cloud backup to S3/R2
# S3_BACKUP_BUCKET=wazema-backups
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
